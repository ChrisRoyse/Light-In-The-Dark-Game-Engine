diff --git a/renderer/shaders/include/litd_fog.glsl b/renderer/shaders/include/litd_fog.glsl
new file mode 100644
index 0000000..7974413
--- /dev/null
+++ b/renderer/shaders/include/litd_fog.glsl
@@ -0,0 +1,47 @@
+// LITD-PATCH: per-fragment fog-of-war texture term (#161).
+//
+// Samples the visibility-grid fog texture (litd/render.FogTexture, an R8 map
+// where 0=hidden, ~0.4=explored, 1=visible) by the fragment's world-space XZ
+// position and dims the surface in three zones: hidden -> near-black,
+// explored -> ~40% dim + desaturated, visible -> full color. The term lives
+// inside the existing terrain/unit draw (no overlay quad) so it costs zero
+// extra draw calls. Gated by LITD_FOG so it compiles out entirely when the
+// surface does not opt in; cost is then zero (matches the litd_teamcolor
+// delimited-block convention for rebase hygiene).
+#ifdef LITD_FOG
+uniform sampler2D LitdFogTex;
+// xy = world-space XZ origin (map min corner); zw = 1 / world XZ extent.
+// fogUV = (worldXZ - origin) * invExtent  ->  one affine transform.
+uniform vec4 LitdFogXform;
+// x = enabled (>= 0.5 applies the term); y,z,w reserved.
+uniform vec4 LitdFogControl;
+in vec3 LitdWorldPos;
+#endif
+
+// LitdApplyFog multiplies color by the fog-of-war dim sampled at this
+// fragment's world position. A no-op (returns color unchanged) when LITD_FOG
+// is undefined or the term is disabled.
+vec4 LitdApplyFog(vec4 color) {
+#ifdef LITD_FOG
+    if (LitdFogControl.x < 0.5) {
+        return color;
+    }
+    // Affine world-XZ -> fog UV. Clamp so a map-corner fragment never wraps the
+    // sampler and pulls fog from the opposite edge (edge case 4).
+    vec2 uv = (LitdWorldPos.xz - LitdFogXform.xy) * LitdFogXform.zw;
+    uv = clamp(uv, 0.0, 1.0);
+    // Bilinear sampling (texture filter LINEAR) gives soft zone edges.
+    float fog = texture(LitdFogTex, uv).r; // 0 hidden, ~0.4 explored, 1 visible
+
+    vec3 rgb = color.rgb;
+    // Desaturate as visibility drops: explored reads greyer, not just darker.
+    float luma = dot(rgb, vec3(0.299, 0.587, 0.114));
+    rgb = mix(vec3(luma), rgb, clamp(fog, 0.0, 1.0));
+    // Dim toward black by the fog factor, with a small floor so fully-hidden
+    // terrain is "near-black" (shape faintly readable) rather than pure 0.
+    rgb *= clamp(fog, 0.06, 1.0);
+    return vec4(rgb, color.a);
+#else
+    return color;
+#endif
+}
