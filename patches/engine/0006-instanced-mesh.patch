+++ b/renderer/instanced_mesh_litd_test.go
@@ -0,0 +1,56 @@
+package renderer
+
+import (
+	"testing"
+
+	"github.com/g3n/engine/camera"
+	"github.com/g3n/engine/core"
+	"github.com/g3n/engine/geometry"
+	"github.com/g3n/engine/graphic"
+	"github.com/g3n/engine/material"
+	"github.com/g3n/engine/math32"
+)
+
+func TestLITDInstancedMeshCullingUsesMergedLocalBoundsFSV(t *testing.T) {
+	scene := core.NewNode()
+	mesh := graphic.NewInstancedMesh(geometry.NewPlane(1, 1), material.NewBasic(), 2)
+	var near math32.Matrix4
+	near.MakeTranslation(0, 0, 0)
+	var far math32.Matrix4
+	far.MakeTranslation(1000, 0, 0)
+	mesh.SetInstanceMatrix(0, &near)
+	mesh.SetInstanceMatrix(1, &far)
+	scene.Add(mesh)
+	scene.UpdateMatrixWorld()
+
+	cam := camera.New(1)
+	cam.SetPosition(0, 0, 8)
+	cam.LookAt(&math32.Vector3{}, &math32.Vector3{X: 0, Y: 1, Z: 0})
+
+	r := litdTestRenderer()
+	before := r.stats
+	bounds := mesh.LocalBoundingBox()
+	r.classifyAndCull(scene, litdTestFrustum(cam), 0)
+	after := r.stats
+	t.Logf("FSV before=%+v bounds=%+v after=%+v queue=%d", before, bounds, after, len(r.graphics))
+
+	if after.VisibleGraphics != 1 || after.CulledGraphics != 0 || len(r.graphics) != 1 {
+		t.Fatalf("mixed near/far instances got visible=%d culled=%d queued=%d, want 1/0/1",
+			after.VisibleGraphics, after.CulledGraphics, len(r.graphics))
+	}
+
+	mesh.SetInstanceMatrix(0, &far)
+	mesh.SetInstanceMatrix(1, &far)
+	scene.UpdateMatrixWorld()
+	r = litdTestRenderer()
+	before = r.stats
+	bounds = mesh.LocalBoundingBox()
+	r.classifyAndCull(scene, litdTestFrustum(cam), 0)
+	after = r.stats
+	t.Logf("FSV edge before=%+v bounds=%+v after=%+v queue=%d", before, bounds, after, len(r.graphics))
+
+	if after.VisibleGraphics != 0 || after.CulledGraphics != 1 || len(r.graphics) != 0 {
+		t.Fatalf("all far instances got visible=%d culled=%d queued=%d, want 0/1/0",
+			after.VisibleGraphics, after.CulledGraphics, len(r.graphics))
+	}
+}
