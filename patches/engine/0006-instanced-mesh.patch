diff --git a/graphic/instanced_mesh.go b/graphic/instanced_mesh.go
new file mode 100644
index 0000000..ed15284
--- /dev/null
+++ b/graphic/instanced_mesh.go
@@ -0,0 +1,262 @@
+// Copyright 2016 The G3N Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style
+// license that can be found in the LICENSE file.
+
+package graphic
+
+import (
+	"github.com/g3n/engine/core"
+	"github.com/g3n/engine/geometry"
+	"github.com/g3n/engine/gls"
+	"github.com/g3n/engine/material"
+	"github.com/g3n/engine/math32"
+)
+
+const (
+	instanceMatrixFloats = 16
+	instanceMatrixAttrib = uint32(8)
+)
+
+// InstancedMesh renders many rigid instances of one geometry and material.
+//
+// LITD-PATCH: G3N has no Go-level instanced graphic. This type is the
+// renderer-facing primitive LitD uses before higher-level batching builds
+// persistent per-instance mirrors and team-color attributes.
+type InstancedMesh struct {
+	Mesh
+
+	instanceCount  int
+	instanceBuffer math32.ArrayF32
+	instanceDirty  bool
+
+	instanceGS     *gls.GLS
+	instanceHandle uint32
+
+	bounds      math32.Box3
+	boundsValid bool
+}
+
+// NewInstancedMesh creates a mesh that draws instanceCount copies.
+func NewInstancedMesh(igeom geometry.IGeometry, imat material.IMaterial, instanceCount int) *InstancedMesh {
+
+	m := new(InstancedMesh)
+	m.Init(igeom, imat, instanceCount)
+	return m
+}
+
+// Init initializes this instanced mesh.
+func (m *InstancedMesh) Init(igeom geometry.IGeometry, imat material.IMaterial, instanceCount int) {
+
+	m.Graphic.Init(m, igeom, gls.TRIANGLES)
+	m.ShaderDefines.Set("LITD_INSTANCING", "1")
+
+	m.uniMm.Init("ModelMatrix")
+	m.uniMVm.Init("ModelViewMatrix")
+	m.uniMVPm.Init("MVP")
+	m.uniNm.Init("NormalMatrix")
+
+	m.bounds.MakeEmpty()
+	m.SetInstanceCount(instanceCount)
+
+	if imat != nil {
+		m.AddMaterial(imat, 0, 0)
+	}
+}
+
+// Dispose releases the instance buffer and embedded graphic resources.
+func (m *InstancedMesh) Dispose() {
+
+	if m.instanceGS != nil && m.instanceHandle != 0 {
+		m.instanceGS.DeleteBuffers(m.instanceHandle)
+	}
+	m.instanceGS = nil
+	m.instanceHandle = 0
+	m.Graphic.Dispose()
+}
+
+// Clone clones this instanced mesh and its instance matrix data.
+func (m *InstancedMesh) Clone() core.INode {
+
+	clone := new(InstancedMesh)
+	clone.Mesh = *m.Mesh.Clone().(*Mesh)
+	clone.SetIGraphic(clone)
+	clone.instanceCount = m.instanceCount
+	clone.instanceBuffer = make(math32.ArrayF32, len(m.instanceBuffer))
+	copy(clone.instanceBuffer, m.instanceBuffer)
+	clone.instanceDirty = true
+	clone.bounds = m.bounds
+	clone.boundsValid = m.boundsValid
+	return clone
+}
+
+// SetMaterial clears all materials and assigns one material to all vertices.
+func (m *InstancedMesh) SetMaterial(imat material.IMaterial) {
+
+	m.Graphic.ClearMaterials()
+	m.Graphic.AddMaterial(m, imat, 0, 0)
+}
+
+// AddMaterial adds a material for a vertex subset.
+func (m *InstancedMesh) AddMaterial(imat material.IMaterial, start, count int) {
+
+	m.Graphic.AddMaterial(m, imat, start, count)
+}
+
+// AddGroupMaterial adds a material for a geometry group.
+func (m *InstancedMesh) AddGroupMaterial(imat material.IMaterial, gindex int) {
+
+	m.Graphic.AddGroupMaterial(m, imat, gindex)
+}
+
+// InstanceCount returns the current number of rendered instances.
+func (m *InstancedMesh) InstanceCount() int {
+
+	return m.instanceCount
+}
+
+// SetInstanceCount resizes the instance list. New entries are identity matrices.
+func (m *InstancedMesh) SetInstanceCount(count int) {
+
+	if count < 0 {
+		panic("InstancedMesh.SetInstanceCount: negative count")
+	}
+	old := m.instanceCount
+	required := count * instanceMatrixFloats
+	if cap(m.instanceBuffer) < required {
+		next := make(math32.ArrayF32, required)
+		copy(next, m.instanceBuffer)
+		m.instanceBuffer = next
+	} else {
+		m.instanceBuffer = m.instanceBuffer[:required]
+	}
+	m.instanceCount = count
+
+	var ident math32.Matrix4
+	ident.Identity()
+	for i := old; i < count; i++ {
+		m.SetInstanceMatrix(i, &ident)
+	}
+	m.instanceDirty = true
+	m.boundsValid = false
+}
+
+// SetInstanceMatrix copies matrix into the specified instance slot.
+func (m *InstancedMesh) SetInstanceMatrix(index int, matrix *math32.Matrix4) {
+
+	if index < 0 || index >= m.instanceCount {
+		panic("InstancedMesh.SetInstanceMatrix: index out of range")
+	}
+	if matrix == nil {
+		panic("InstancedMesh.SetInstanceMatrix: nil matrix")
+	}
+	copy(m.instanceBuffer[index*instanceMatrixFloats:], matrix[:])
+	m.instanceDirty = true
+	m.boundsValid = false
+}
+
+// SetInstanceMatrices replaces all instance transforms.
+func (m *InstancedMesh) SetInstanceMatrices(matrices []math32.Matrix4) {
+
+	m.SetInstanceCount(len(matrices))
+	for i := range matrices {
+		m.SetInstanceMatrix(i, &matrices[i])
+	}
+}
+
+// InstanceMatrix copies one instance matrix into target and returns target.
+func (m *InstancedMesh) InstanceMatrix(index int, target *math32.Matrix4) *math32.Matrix4 {
+
+	if index < 0 || index >= m.instanceCount {
+		panic("InstancedMesh.InstanceMatrix: index out of range")
+	}
+	if target == nil {
+		target = math32.NewMatrix4()
+	}
+	m.instanceBuffer.GetMatrix4(index*instanceMatrixFloats, target)
+	return target
+}
+
+// LocalBoundingBox returns a conservative box around all local instances.
+func (m *InstancedMesh) LocalBoundingBox() math32.Box3 {
+
+	if !m.boundsValid {
+		m.recalculateBounds()
+	}
+	return m.bounds
+}
+
+// RenderGraphicMaterial is called by GraphicMaterial.Render for this type.
+func (m *InstancedMesh) RenderGraphicMaterial(gs *gls.GLS, rinfo *core.RenderInfo, grmat *GraphicMaterial) {
+
+	if m.instanceCount == 0 {
+		return
+	}
+
+	grmat.imat.RenderSetup(gs)
+
+	gr := grmat.igraphic.GetGraphic()
+	gr.igeom.RenderSetup(gs)
+	m.transferInstances(gs)
+	grmat.igraphic.RenderSetup(gs, rinfo)
+
+	count := grmat.count
+	geom := gr.igeom.GetGeometry()
+	indices := geom.Indices()
+	if indices.Size() > 0 {
+		if count == 0 {
+			count = indices.Size()
+		}
+		gs.DrawElementsInstanced(gr.mode, int32(count), gls.UNSIGNED_INT, 4*uint32(grmat.start), int32(m.instanceCount))
+	} else {
+		if count == 0 {
+			count = geom.Items()
+		}
+		gs.DrawArraysInstanced(gr.mode, int32(grmat.start), int32(count), int32(m.instanceCount))
+	}
+}
+
+func (m *InstancedMesh) transferInstances(gs *gls.GLS) {
+
+	if m.instanceGS != gs {
+		m.instanceGS = gs
+		m.instanceHandle = 0
+		m.instanceDirty = true
+	}
+	if m.instanceHandle == 0 {
+		m.instanceHandle = gs.GenBuffer()
+		m.instanceDirty = true
+	}
+
+	gs.BindBuffer(gls.ARRAY_BUFFER, m.instanceHandle)
+	if m.instanceDirty {
+		gs.BufferData(gls.ARRAY_BUFFER, m.instanceBuffer.Bytes(), m.instanceBuffer.ToFloat32(), gls.DYNAMIC_DRAW)
+		m.instanceDirty = false
+	}
+
+	stride := int32(instanceMatrixFloats) * gls.FloatSize
+	for col := uint32(0); col < 4; col++ {
+		loc := instanceMatrixAttrib + col
+		gs.EnableVertexAttribArray(loc)
+		gs.VertexAttribPointer(loc, 4, gls.FLOAT, false, stride, col*4*uint32(gls.FloatSize))
+		gs.VertexAttribDivisor(loc, 1)
+	}
+}
+
+func (m *InstancedMesh) recalculateBounds() {
+
+	m.bounds.MakeEmpty()
+	if m.instanceCount == 0 {
+		m.boundsValid = true
+		return
+	}
+
+	base := m.GetGeometry().BoundingBox()
+	var mat math32.Matrix4
+	var instBox math32.Box3
+	for i := 0; i < m.instanceCount; i++ {
+		m.instanceBuffer.GetMatrix4(i*instanceMatrixFloats, &mat)
+		instBox.Copy(&base).ApplyMatrix4(&mat)
+		m.bounds.Union(&instBox)
+	}
+	m.boundsValid = true
+}
diff --git a/graphic/instanced_mesh_litd_test.go b/graphic/instanced_mesh_litd_test.go
new file mode 100644
index 0000000..ad5e677
--- /dev/null
+++ b/graphic/instanced_mesh_litd_test.go
@@ -0,0 +1,92 @@
+package graphic
+
+import (
+	"testing"
+
+	"github.com/g3n/engine/geometry"
+	"github.com/g3n/engine/material"
+	"github.com/g3n/engine/math32"
+)
+
+func TestLITDInstancedMeshBoundsAndMatricesFSV(t *testing.T) {
+	geom := geometry.NewPlane(2, 2)
+	mat := material.NewBasic()
+	mesh := NewInstancedMesh(geom, mat, 0)
+
+	before := mesh.LocalBoundingBox()
+	t.Logf("FSV before count=%d bounds=%+v", mesh.InstanceCount(), before)
+	if !before.Empty() {
+		t.Fatalf("empty instanced mesh bounds = %+v, want empty", before)
+	}
+
+	mesh.SetInstanceCount(2)
+	var translated math32.Matrix4
+	translated.MakeTranslation(3, 4, 0)
+	mesh.SetInstanceMatrix(1, &translated)
+	after := mesh.LocalBoundingBox()
+	t.Logf("FSV after count=%d bounds=%+v", mesh.InstanceCount(), after)
+
+	if mesh.InstanceCount() != 2 {
+		t.Fatalf("count=%d, want 2", mesh.InstanceCount())
+	}
+	if after.Min.X != -1 || after.Min.Y != -1 || after.Max.X != 4 || after.Max.Y != 5 {
+		t.Fatalf("merged bounds=%+v, want min(-1,-1) max(4,5)", after)
+	}
+
+	var readback math32.Matrix4
+	mesh.InstanceMatrix(1, &readback)
+	if readback != translated {
+		t.Fatalf("matrix readback=%v, want %v", readback, translated)
+	}
+}
+
+func TestLITDInstancedMeshMaterialOwnershipFSV(t *testing.T) {
+	mesh := NewInstancedMesh(geometry.NewPlane(1, 1), material.NewBasic(), 1)
+	before := mesh.Materials()[0].IGraphic()
+	t.Logf("FSV before material graphic=%T", before)
+	if _, ok := before.(GraphicMaterialRenderer); !ok {
+		t.Fatalf("initial material graphic %T does not render instanced", before)
+	}
+
+	mesh.SetMaterial(material.NewBasic())
+	afterSet := mesh.Materials()[0].IGraphic()
+	t.Logf("FSV after SetMaterial graphic=%T", afterSet)
+	if _, ok := afterSet.(GraphicMaterialRenderer); !ok {
+		t.Fatalf("SetMaterial graphic %T does not render instanced", afterSet)
+	}
+
+	mesh.ClearMaterials()
+	mesh.AddMaterial(material.NewBasic(), 0, 0)
+	afterAdd := mesh.Materials()[0].IGraphic()
+	t.Logf("FSV after AddMaterial graphic=%T", afterAdd)
+	if _, ok := afterAdd.(GraphicMaterialRenderer); !ok {
+		t.Fatalf("AddMaterial graphic %T does not render instanced", afterAdd)
+	}
+}
+
+func TestLITDInstancedMeshInvalidInputsFSV(t *testing.T) {
+	mesh := NewInstancedMesh(geometry.NewPlane(1, 1), material.NewBasic(), 1)
+	cases := []struct {
+		name string
+		fn   func()
+	}{
+		{name: "negative-count", fn: func() { mesh.SetInstanceCount(-1) }},
+		{name: "nil-matrix", fn: func() { mesh.SetInstanceMatrix(0, nil) }},
+		{name: "index-out-of-range", fn: func() {
+			var m math32.Matrix4
+			m.Identity()
+			mesh.SetInstanceMatrix(1, &m)
+		}},
+	}
+	for _, tc := range cases {
+		t.Run(tc.name, func(t *testing.T) {
+			defer func() {
+				if recover() == nil {
+					t.Fatalf("%s did not panic", tc.name)
+				}
+				t.Logf("FSV edge %s panic observed; count=%d", tc.name, mesh.InstanceCount())
+			}()
+			tc.fn()
+		})
+	}
+}
