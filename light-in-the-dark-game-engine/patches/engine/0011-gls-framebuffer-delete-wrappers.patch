+// LITD-PATCH: Go-side wrapper over the already-loaded glDeleteFramebuffers so
+// offscreen render targets (litd/render.PortraitTarget, #193) can release their
+// framebuffer object instead of leaking it. Mirrors DeleteTextures.
+func (gs *GLS) DeleteFramebuffers(fbos ...uint32) {
+
+	C.glDeleteFramebuffers(C.GLsizei(len(fbos)), (*C.GLuint)(&fbos[0]))
+}
+
+// LITD-PATCH: Go-side wrapper over the already-loaded glDeleteRenderbuffers so
+// offscreen render targets can release their depth/stencil renderbuffer.
+func (gs *GLS) DeleteRenderbuffers(rbos ...uint32) {
+
+	C.glDeleteRenderbuffers(C.GLsizei(len(rbos)), (*C.GLuint)(&rbos[0]))
+}
