+// copyReuse copies other into ss but REUSES ss's existing Defines backing map
+// (clear-in-place + refill) instead of make()-ing a fresh one, so a steady-state
+// SetProgram does not allocate a map per graphic-material per frame (LITD-PATCH
+// #537 — the dominant remaining steady-state alloc after 0015). It allocates only
+// when ss has no map yet (first use) or must grow. Use ONLY for transient/current
+// specs that ss owns exclusively (sm.scratch, sm.specs); NEVER for specs retained
+// in the program cache — those must keep their own stable map (use copy()).
+func (ss *ShaderSpecs) copyReuse(other *ShaderSpecs) {
+
+	defs := ss.Defines // preserve our backing map across the struct copy
+	*ss = *other
+	if other.Defines == nil {
+		if defs != nil {
+			for k := range defs {
+				delete(defs, k)
+			}
+		}
+		ss.Defines = defs
+		return
+	}
+	if defs == nil {
+		defs = gls.ShaderDefines(make(map[string]string, len(other.Defines)))
+	} else {
+		for k := range defs {
+			delete(defs, k)
+		}
+	}
+	for k, v := range map[string]string(other.Defines) {
+		defs[k] = v
+	}
+	ss.Defines = defs
+}
