@@ -14,11 +14,12 @@ import (
 
 // Mesh is a Graphic with uniforms for the model, view, projection, and normal matrices.
 type Mesh struct {
-	Graphic             // Embedded graphic
-	uniMm   gls.Uniform // Model matrix uniform location cache
