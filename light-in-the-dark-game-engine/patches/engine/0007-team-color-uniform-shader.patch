diff --git a/renderer/shaders/include/litd_teamcolor.glsl b/renderer/shaders/include/litd_teamcolor.glsl
new file mode 100644
index 0000000..63e2f2a
--- /dev/null
+++ b/renderer/shaders/include/litd_teamcolor.glsl
@@ -0,0 +1,43 @@
+// LITD-PATCH: per-graphic team color and presentation scalar channel.
+#ifdef LITD_TEAMCOLOR
+uniform vec3 LitdTeamColor;
+uniform vec4 LitdTeamColorZone;
+// x = hit flash, y = fade alpha, z = fog dim, w = enabled flag.
+uniform vec4 LitdFxScalars;
+#endif
+
+vec3 getTeamColor() {
+#ifdef LITD_TEAMCOLOR
+    return LitdTeamColor;
+#else
+    return vec3(1.0);
+#endif
+}
+
+bool LitdInTeamColorZone(vec2 uv) {
+#ifdef LITD_TEAMCOLOR
+    return uv.x >= LitdTeamColorZone.x && uv.x <= LitdTeamColorZone.z &&
+           uv.y >= LitdTeamColorZone.y && uv.y <= LitdTeamColorZone.w;
+#else
+    return false;
+#endif
+}
+
+vec4 LitdApplyTeamColor(vec4 color, vec2 uv) {
+#ifdef LITD_TEAMCOLOR
+    if (LitdFxScalars.w < 0.5) {
+        return color;
+    }
+
+    vec4 outColor = color;
+    if (LitdInTeamColorZone(uv)) {
+        outColor.rgb *= getTeamColor();
+    }
+    outColor.rgb = mix(outColor.rgb, vec3(1.0), clamp(LitdFxScalars.x, 0.0, 1.0));
+    outColor.rgb *= clamp(LitdFxScalars.z, 0.0, 1.0);
+    outColor.a *= clamp(LitdFxScalars.y, 0.0, 1.0);
+    return outColor;
+#else
+    return color;
+#endif
+}
