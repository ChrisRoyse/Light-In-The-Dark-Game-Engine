# Vendored reference repositories (cloned, not ours to track)
repoes/

# Go
/bin/
*.exe
*.test
*.out

# Editor/OS
.idea/
.vscode/
.DS_Store

# Scratch debug binaries/code
/cmd/dbg/
# Test/FSV artifacts (screenshots, state dumps)
/artifacts/
benchmarks/history.jsonl

# Asset binaries: NOT tracked. assets/MANIFEST is the tracked provenance
# ledger (path/pack/source/license/sha256); restore binaries from the
# MANIFEST source URLs. assetcheck runs locally against the real files.
assets/**/*.glb
assets/**/*.png
assets/**/*.ogg

# apilint build artifact (go build ./tools/apilint writes ./apilint) — never track
/apilint
