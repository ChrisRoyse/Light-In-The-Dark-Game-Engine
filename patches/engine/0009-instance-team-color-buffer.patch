+func TestLITDInstancedMeshTeamColorsFSV(t *testing.T) {
+	mesh := NewInstancedMesh(geometry.NewPlane(1, 1), material.NewBasic(), 2)
+	before := mesh.InstanceTeamColor(0, nil)
+	t.Logf("FSV instanced team color BEFORE count=%d bytes=%d color0=%+v defines=%+v", mesh.InstanceCount(), mesh.InstanceTeamColorBufferBytes(), before, mesh.ShaderDefines)
+	if before.R != 1 || before.G != 1 || before.B != 1 {
+		t.Fatalf("default team color = %+v, want white", before)
+	}
+	if mesh.InstanceTeamColorBufferBytes() != 2*3*4 {
+		t.Fatalf("team color buffer bytes = %d, want 24", mesh.InstanceTeamColorBufferBytes())
+	}
+	if mesh.ShaderDefines["LITD_INSTANCE_TEAMCOLOR"] != "1" || mesh.ShaderDefines["LITD_TEAMCOLOR"] != "1" {
+		t.Fatalf("instanced team color shader defines missing: %+v", mesh.ShaderDefines)
+	}
+
+	want := math32.Color{R: 0.1, G: 0.6, B: 0.9}
+	mesh.SetInstanceTeamColor(1, &want)
+	var got math32.Color
+	mesh.InstanceTeamColor(1, &got)
+	t.Logf("FSV instanced team color AFTER color1=%+v bytes=%d", got, mesh.InstanceTeamColorBufferBytes())
+	if got != want {
+		t.Fatalf("team color readback = %+v, want %+v", got, want)
+	}
+
+	clone := mesh.Clone().(*InstancedMesh)
+	var cloneColor math32.Color
+	clone.InstanceTeamColor(1, &cloneColor)
+	if cloneColor != want {
+		t.Fatalf("clone team color = %+v, want %+v", cloneColor, want)
+	}
+
+	mesh.SetInstanceCount(3)
+	var newSlot math32.Color
+	mesh.InstanceTeamColor(2, &newSlot)
+	t.Logf("FSV instanced team color grow count=%d bytes=%d newSlot=%+v", mesh.InstanceCount(), mesh.InstanceTeamColorBufferBytes(), newSlot)
+	if newSlot.R != 1 || newSlot.G != 1 || newSlot.B != 1 {
+		t.Fatalf("new slot color = %+v, want white", newSlot)
+	}
+}
