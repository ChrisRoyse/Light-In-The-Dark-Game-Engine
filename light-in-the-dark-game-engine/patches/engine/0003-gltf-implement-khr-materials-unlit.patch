-// TODO
-// loadMaterialUnlit receives an interface value describing a KHR_materials_unlit extension,
-// decodes it and returns a Material closest to the specified description.
-// The specification of this extension is at:
+// LITD-PATCH: implement KHR_materials_unlit (upstream stub returned
+// nil, nil, which the LoadMaterial dispatch cached as a nil material —
+// every unlit-tagged primitive rendered nothing).
+//
+// loadMaterialUnlit builds a lighting-independent material from the
+// material's pbrMetallicRoughness baseColor per the extension spec:
 // https://github.com/KhronosGroup/glTF/tree/master/extensions/2.0/Khronos/KHR_materials_unlit
-func (g *GLTF) loadMaterialUnlit(ext interface{}) (material.IMaterial, error) {
+// The fragment color is baseColorFactor × baseColorTexture × vertex
+// color when COLOR_0 is present. Implemented as a Standard material with
+// UseLightNone: the standard shader's noLights path skips all light
+// uploads and outputs the base-color path directly.
+func (g *GLTF) loadMaterialUnlit(m *Material) (material.IMaterial, error) {
 
-	return nil, nil
+	mat := material.NewStandard(&math32.Color{R: 1, G: 1, B: 1})
+	mat.SetUseLights(material.UseLightNone)
+	mat.SetEmissiveColor(&math32.Color{R: 0, G: 0, B: 0})
+	mat.SetSpecularColor(&math32.Color{R: 0, G: 0, B: 0})
+
+	if m.DoubleSided {
+		mat.SetSide(material.SideDouble)
+	} else {
+		mat.SetSide(material.SideFront)
+	}
+	if m.AlphaMode == "BLEND" {
+		mat.SetTransparent(true)
+	}
+
+	if pbr := m.PbrMetallicRoughness; pbr != nil {
+		if f := pbr.BaseColorFactor; f != nil {
+			mat.SetColor(&math32.Color{R: f[0], G: f[1], B: f[2]})
+			mat.SetOpacity(f[3])
+		}
+		if pbr.BaseColorTexture != nil {
+			tex, err := g.LoadTexture(pbr.BaseColorTexture.Index)
+			if err != nil {
+				return nil, err
+			}
+			mat.AddTexture(tex)
+		}
+	}
+	return mat, nil
 }
