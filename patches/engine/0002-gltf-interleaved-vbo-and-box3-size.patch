+// LITD-PATCH: addSizedAttributeToVBO registers an attribute with the
+// accessor's actual element count instead of gls's fixed per-type size.
+// Needed for interleaved layouts where e.g. COLOR_0 is VEC4 but gls
+// assumes VertexColor is 3 elements — the stride accounting must match
+// the file's layout exactly or every following attribute misreads.
+func (g *GLTF) addSizedAttributeToVBO(vbo *gls.VBO, attribName string, itemSize int, byteOffset uint32) {
+
+	aType, ok := AttributeName[attribName]
+	if !ok {
+		log.Warn(fmt.Sprintf("Attribute %v is not supported!", attribName))
+		return
+	}
+	vbo.AddAttribOffsetSize(aType, byteOffset, int32(itemSize))
