+// LITD-PATCH: recordStateChange increments the frame state-change counters when the draw state changes.
+func (r *Renderer) recordStateChange(grmat *graphic.GraphicMaterial, mat *material.Material, geom *geometry.Geometry) {
+	key := renderStateKey{
+		material:     mat,
+		geometry:     geom,
+		shader:       mat.Shader(),
+		shaderUnique: mat.ShaderUnique(),
+		useLights:    mat.UseLights(),
+		textureCount: mat.TextureCount(),
+		side:         mat.Side(),
+		transparent:  mat.Transparent(),
+	}
+	if r.stateValid && r.lastState == key {
+		return
+	}
+	r.stateValid = true
+	r.lastState = key
+	r.stats.StateChanges++
+	switch r.passFor(grmat) {
+	case renderPassGUI:
+		r.stats.GUIStates++
+	case renderPassTransparent:
+		r.stats.TransparentStates++
+	default:
+		r.stats.OpaqueStates++
+	}
+}
+
+// LITD-PATCH: recordDrawCalls attributes GL draw calls to the current coarse render pass.
+func (r *Renderer) recordDrawCalls(grmat *graphic.GraphicMaterial, n int) {
+	if n <= 0 {
+		return
+	}
+	r.stats.DrawCalls += n
+	switch r.passFor(grmat) {
+	case renderPassGUI:
+		r.stats.GUIDrawCalls += n
+	case renderPassTransparent:
+		r.stats.TransparentDrawCalls += n
+	default:
+		r.stats.OpaqueDrawCalls += n
+	}
+}
+
+// LITD-PATCH: passFor treats GUI panels as their own pass even when queued with opaque/translucent materials.
+func (r *Renderer) passFor(grmat *graphic.GraphicMaterial) renderPass {
+	if _, ok := grmat.IGraphic().(gui.IPanel); ok {
+		return renderPassGUI
+	}
+	return r.currentPass
+}
diff --git a/renderer/stats_litd_test.go b/renderer/stats_litd_test.go
new file mode 100644
index 0000000..735eb69
--- /dev/null
+++ b/renderer/stats_litd_test.go
@@ -0,0 +1,158 @@
+package renderer
+
+import (
+	"testing"
+
+	"github.com/g3n/engine/camera"
+	"github.com/g3n/engine/core"
+	"github.com/g3n/engine/geometry"
+	"github.com/g3n/engine/graphic"
+	"github.com/g3n/engine/gui"
+	"github.com/g3n/engine/material"
+	"github.com/g3n/engine/math32"
+)
+
+func litdTestFrustum(cam *camera.Camera) *math32.Frustum {
+	var view, proj, combined math32.Matrix4
+	cam.ViewMatrix(&view)
+	cam.ProjMatrix(&proj)
+	combined.MultiplyMatrices(&proj, &view)
+	return math32.NewFrustumFromMatrix(&combined)
+}
+
+func litdTestRenderer() *Renderer {
+	return &Renderer{
+		zLayers:    map[int][]gui.IPanel{0: nil},
+		zLayerKeys: []int{0},
+	}
+}
+
+func litdTestMesh(geom geometry.IGeometry, mat material.IMaterial, x, y, z float32) *graphic.Mesh {
+	mesh := graphic.NewMesh(geom, mat)
+	mesh.SetPosition(x, y, z)
+	return mesh
+}
+
+func TestLITDFrameStatsClassifyVisibleAndCulledGraphics(t *testing.T) {
+	scene := core.NewNode()
+	geom := geometry.NewBox(1, 1, 1)
+	mat := material.NewBasic()
+	visible := litdTestMesh(geom, mat, 0, 0, 0)
+	culled := litdTestMesh(geom, mat, 1000, 0, 0)
+	scene.Add(visible)
+	scene.Add(culled)
+	scene.UpdateMatrixWorld()
+
+	cam := camera.New(1)
+	cam.SetPosition(0, 0, 8)
+	cam.LookAt(&math32.Vector3{}, &math32.Vector3{X: 0, Y: 1, Z: 0})
+
+	r := litdTestRenderer()
+	before := r.stats
+	r.classifyAndCull(scene, litdTestFrustum(cam), 0)
+	after := r.stats
+	t.Logf("FSV classify before=%+v after=%+v renderQueue=%d", before, after, len(r.graphics))
+
+	if after.VisibleGraphics != 1 || after.CulledGraphics != 1 || len(r.graphics) != 1 {
+		t.Fatalf("classify stats got visible=%d culled=%d queued=%d, want 1/1/1",
+			after.VisibleGraphics, after.CulledGraphics, len(r.graphics))
+	}
+}
+
+func TestLITDFrameStatsClassifyUncullableAndHiddenEdges(t *testing.T) {
+	scene := core.NewNode()
+	geom := geometry.NewBox(1, 1, 1)
+	mat := material.NewBasic()
+	uncullable := litdTestMesh(geom, mat, 1000, 0, 0)
+	uncullable.SetCullable(false)
+	hidden := litdTestMesh(geom, mat, 0, 0, 0)
+	hidden.SetVisible(false)
+	scene.Add(uncullable)
+	scene.Add(hidden)
+	scene.UpdateMatrixWorld()
+
+	cam := camera.New(1)
+	cam.SetPosition(0, 0, 8)
+	cam.LookAt(&math32.Vector3{}, &math32.Vector3{X: 0, Y: 1, Z: 0})
+
+	r := litdTestRenderer()
+	before := r.stats
+	r.classifyAndCull(scene, litdTestFrustum(cam), 0)
+	after := r.stats
+	t.Logf("FSV classify edges before=%+v after=%+v renderQueue=%d", before, after, len(r.graphics))
+
+	if after.VisibleGraphics != 1 || after.CulledGraphics != 0 || len(r.graphics) != 1 {
+		t.Fatalf("edge classify stats got visible=%d culled=%d queued=%d, want 1/0/1",
+			after.VisibleGraphics, after.CulledGraphics, len(r.graphics))
+	}
+}
+
+func TestLITDFrameStatsStateChangeSharedVsDifferentMaterials(t *testing.T) {
+	geom := geometry.NewBox(1, 1, 1)
+	shared := material.NewBasic()
+	first := litdTestMesh(geom, shared, 0, 0, 0)
+	secondShared := litdTestMesh(geom, shared, 1, 0, 0)
+	secondDifferent := litdTestMesh(geom, material.NewBasic(), 2, 0, 0)
+
+	firstMat := first.Materials()[0]
+	sharedMat := secondShared.Materials()[0]
+	differentMat := secondDifferent.Materials()[0]
+	r := litdTestRenderer()
+
+	before := r.stats
+	r.recordStateChange(&firstMat, firstMat.IMaterial().GetMaterial(), first.GetGeometry())
+	r.recordStateChange(&sharedMat, sharedMat.IMaterial().GetMaterial(), secondShared.GetGeometry())
+	afterShared := r.stats
+	r.recordStateChange(&differentMat, differentMat.IMaterial().GetMaterial(), secondDifferent.GetGeometry())
+	afterDifferent := r.stats
+	t.Logf("FSV state before=%+v afterShared=%+v afterDifferent=%+v", before, afterShared, afterDifferent)
+
+	if afterShared.StateChanges != 1 || afterShared.OpaqueStates != 1 {
+		t.Fatalf("shared material/geometry changed state: %+v", afterShared)
+	}
+	if afterDifferent.StateChanges != 2 || afterDifferent.OpaqueStates != 2 {
+		t.Fatalf("different material did not change state: %+v", afterDifferent)
+	}
+}
+
+func TestLITDFrameStatsDrawCallPassBuckets(t *testing.T) {
+	geom := geometry.NewBox(1, 1, 1)
+	mat := material.NewBasic()
+	mesh := litdTestMesh(geom, mat, 0, 0, 0)
+	meshMat := mesh.Materials()[0]
+	panel := gui.NewPanel(32, 16)
+	panelMat := panel.GetGraphic().Materials()[0]
+
+	r := litdTestRenderer()
+	before := r.stats
+	r.currentPass = renderPassOpaque
+	r.recordDrawCalls(&meshMat, 1)
+	r.currentPass = renderPassTransparent
+	r.recordDrawCalls(&meshMat, 2)
+	r.recordDrawCalls(&panelMat, 3)
+	after := r.stats
+	t.Logf("FSV draw pass buckets before=%+v after=%+v", before, after)
+
+	if after.DrawCalls != 6 || after.OpaqueDrawCalls != 1 || after.TransparentDrawCalls != 2 || after.GUIDrawCalls != 3 {
+		t.Fatalf("draw buckets got total=%d opaque=%d transparent=%d gui=%d, want 6/1/2/3",
+			after.DrawCalls, after.OpaqueDrawCalls, after.TransparentDrawCalls, after.GUIDrawCalls)
+	}
+}
+
+func TestLITDFrameStatsRecordersZeroAlloc(t *testing.T) {
+	geom := geometry.NewBox(1, 1, 1)
+	mat := material.NewBasic()
+	mesh := litdTestMesh(geom, mat, 0, 0, 0)
+	meshMat := mesh.Materials()[0]
+	r := litdTestRenderer()
+	r.recordStateChange(&meshMat, meshMat.IMaterial().GetMaterial(), mesh.GetGeometry())
+
+	allocs := testing.AllocsPerRun(1000, func() {
+		r.recordStateChange(&meshMat, meshMat.IMaterial().GetMaterial(), mesh.GetGeometry())
+		r.recordDrawCalls(&meshMat, 1)
+	})
+	t.Logf("FSV recorder allocs/op=%v stats=%+v", allocs, r.stats)
+	if allocs != 0 {
+		t.Fatalf("recorders allocated: %v", allocs)
+	}
+}
