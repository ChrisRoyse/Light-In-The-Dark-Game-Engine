# ── Claude Code local data ─────────────────────────────────────────────
# Session worktrees grew to 15+ GB — never track. Same for credentials and
# per-session scratch state. settings.json / agents / commands are kept.
.claude/worktrees/
.claude/.credentials.json
.claude/shell-snapshots/
.claude/todos/
.claude/projects/
.claude/history.jsonl
.claude/statsig/

# ── Secrets ────────────────────────────────────────────────────────────
# .env.example templates are still tracked (pattern below only hits real ones).
**/.env
**/.env.local
**/.env.*.local
*.pem
*.key
*.pfx
*.p12

# ── OS / editor ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
