+// LITD-PATCH: AddAttribOffsetSize registers a typed attribute at an
+// explicit byte offset with an explicit element count, overriding the
+// fixed attribTypeSizeMap entry. Needed for interleaved glTF buffers
+// where e.g. COLOR_0 is VEC4 while gls assumes VertexColor has 3
+// elements: the type must stay set (BoundingBox/ReadVertices/culling
+// look attributes up by Type) and the size must match the file layout
+// (StrideSize accounting drives the GL stride).
+func (vbo *VBO) AddAttribOffsetSize(atype AttribType, byteOffset uint32, numElements int32) *VBO {
+
+	vbo.attribs = append(vbo.attribs, VBOattrib{
+		Type:        atype,
+		Name:        attribTypeNameMap[atype],
+		ByteOffset:  byteOffset,
+		NumElements: numElements,
+		ElementType: FLOAT,
+	})
+	return vbo
+}
